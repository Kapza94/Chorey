{
  "expo": {
    "name": "Chorey",
    "slug": "chorey",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "chorey",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.chorey.mobile"
    },
    "android": {
      "package": "app.chorey.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2A2018"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-sqlite",
      "expo-image",
      "expo-notifications",
      "expo-splash-screen",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 260,
          "resizeMode": "contain",
          "backgroundColor": "#F6EFE3",
          "dark": {
            "image": "./assets/splash-icon-dark.png",
            "backgroundColor": "#1C1814"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "icon": "./assets/icon.png"
  }
}
