{
  "expo": {
    "name": "Chorey",
    "slug": "chorey",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "chorey",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.chorey.mobile"
    },
    "android": {
      "package": "app.chorey.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#F6EFE3"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-sqlite",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
